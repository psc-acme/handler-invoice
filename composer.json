{
    "name": "psc-acme/handler-invoice",
    "description": "Package handler-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\HandlerInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/finder": "^7.0",
        "psr/event-dispatcher": "^1.0",
        "league/flysystem": "^3.0",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}